# Copy to `.env.local` (or `.env`) and fill in real values. Never commit files
# that contain production secrets.

# --- Database (required for Drizzle / app) ---
DATABASE_URL=postgresql://user:password@host:5432/ratatouille?sslmode=require
# Direct Neon URL for migrations (`drizzle-kit`); falls back to DATABASE_URL
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/ratatouille?sslmode=require

# --- Auth.js / NextAuth (recommended in production) ---
AUTH_SECRET=replace-with-a-long-random-string
# Public URL of the app, e.g. https://your-app.vercel.app (helps OAuth callbacks)
AUTH_URL=http://localhost:3000

# --- Google OAuth (optional; omit to run without Google sign-in) ---
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret

# --- Google Geocoding (optional; business onboarding geocodes when set) ---
GOOGLE_GEOCODING_API_KEY=replace-with-google-geocoding-api-key

# --- Google Cloud Vision (optional; OCR uses ADC or JSON key fields below) ---
GOOGLE_CLOUD_PROJECT_ID=replace-with-google-cloud-project-id
# Alias supported by the OCR client:
GOOGLE_CLOUD_PROJECT=replace-with-google-cloud-project-id
GOOGLE_CLOUD_CLIENT_EMAIL=replace-with-google-cloud-client-email
# Use literal \n for newlines inside the quoted key, or a single-line PEM
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Cloudinary (optional; listing images use local `public/uploads` when unset) ---
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

# --- Web Push / VAPID (optional; alerts degrade gracefully when unset) ---
VAPID_SUBJECT=mailto:alerts@example.com
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key

# --- Stripe (required for Phase 6 payments; obtain from https://dashboard.stripe.com/test/apikeys) ---
# Server-only secret key (starts sk_test_). Must NEVER be prefixed NEXT_PUBLIC_.
STRIPE_SECRET_KEY=sk_test_replace-with-test-mode-secret-key
# Webhook signing secret (starts whsec_). From the Stripe Dashboard webhook endpoint
# settings, or from the local `stripe listen` CLI output.
STRIPE_WEBHOOK_SECRET=whsec_replace-with-webhook-signing-secret
# Browser publishable key (starts pk_test_). Intentionally NEXT_PUBLIC_ -- exposed to clients.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-with-test-mode-publishable-key

# --- Uber Direct (optional for Phase 7 delivery; UI falls back to local demo stubs when unset) ---
# OAuth client id + secret from Uber Direct sandbox/test mode.
UBER_DIRECT_CLIENT_ID=replace-with-uber-direct-client-id
UBER_DIRECT_CLIENT_SECRET=replace-with-uber-direct-client-secret
# Customer id used by the self-serve Direct API (`/v1/customers/<customer_id>/...`).
UBER_DIRECT_CUSTOMER_ID=replace-with-uber-direct-customer-id
# Webhook signing key used to verify x-uber-signature on /api/webhooks/uber-direct.
UBER_DIRECT_WEBHOOK_SIGNING_KEY=replace-with-uber-direct-webhook-signing-key

# --- Demo controls (optional for Phase 8 scripted walkthrough tools) ---
# Set to 1 to expose the guarded in-app/operator demo controls.
DEMO_MODE_ENABLED=0
# Optional bearer/x-demo-token value for calling internal demo endpoints from curl or the VM.
DEMO_CONTROL_TOKEN=replace-with-demo-control-token
